PORT=8000
MONGO_URI=mongodb://localhost:27017/cmp-garage

# JWT auth configuration
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Optional company profile values used in PDFs
COMPANY_NAME=CMP Garage
COMPANY_ADDRESS=123 Marina Drive\nEllenton, FL 34222
COMPANY_PHONE=(555) 123-4567
COMPANY_EMAIL=service@cmpgarage.example

# Optional SMTP configuration used by email endpoints
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=service@cmpgarage.example
MAIL_PASS=replace_with_mail_password
MAIL_FROM=CMP Garage <service@cmpgarage.example>
MAIL_SERVICE=
MAIL_COPY_TO=
MAIL_TO=
