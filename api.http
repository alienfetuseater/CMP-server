############################################################
# AUTH ROUTES
############################################################

### Register user
POST {{host}}/auth/register
Content-Type: application/json

{
  "name": "mkaepernik",
  "email": "alienfetuseater@gmail.com",
  "password": "MY1house"
}

### Login user
POST {{host}}/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "ChangeMe123!"
}

### Get authenticated user (requires token)
GET {{host}}/auth/me
Authorization: Bearer {{authToken}}


############################################################
# CUSTOMER ROUTES
############################################################

### Create Customer
POST {{host}}/newCustomer
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Robert Hayes",
  "phone": "555-6612",
  "email": "robert.hayes@example.com",
  "address": "9 Lighthouse Point, Ellenton, FL",
  "createdAt": "2026-07-11T11:30:00Z",
  "vesselIds": [
    "66c0a1f9e3b4a9c2d4fab555"
  ]
}


### Search for customers with the name "John"
GET {{host}}/searchCustomers?name=mike
Authorization: Bearer {{authToken}}

# this customer_id was copied from the results of the previous request to be used in the following request
@customer_id = 6a56db24cb9b49d3356fdcd8

### Get Customer Profile for the chosen result
GET {{host}}/getCustomerProfile?id={{customer_id}}
Authorization: Bearer {{authToken}}

### Get all customers
GET {{host}}/getAllCustomers
Authorization: Bearer {{authToken}}

### Create New Vessel
POST {{host}}/newBoat
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "customerId": "66c0a1f9e3b4a9c2d4fab666",
  "owner": "Tina Wallace",
  "customerName": "Tina Wallace",
  "customerPhone": "555-8834",
  "vesselName": "Reel Therapy",
  "vesselMake": "Sea Hunt",
  "vesselYear": 2018,
  "hullIdNumber": "SHGF25-2018TWX",
  "numberOfEngines": 2,
  "engineSerialNumbers": [
    "YAM-F150-998811",
    "YAM-F150-998812"
  ],
  "generator": false,
  "boatLocation": "trailor",
  "engineMake": "Yamaha",
  "engineModel": "F150",
  "engineHours": 410
}


### search for vessels with the name "Sea Ray"
GET {{host}}/searchVessels?name=Sea Ray
Authorization: Bearer {{authToken}}

### return all vessels
GET {{host}}/getAllBoats
Authorization: Bearer {{authToken}}

